
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
       FUNÇÕES BASE
    ============================== */

    function isAuthenticated() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated()
        && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    /* =============================
       VALIDADORES
    ============================== */

    function isValidUserProfile(data) {
      return data.keys().hasOnly([
        'displayName',
        'email',
        'createdAt',
        'isAdmin',
        'termsAccepted'
      ])
      && data.displayName is string
      && data.email is string
      && data.createdAt is timestamp
      && data.isAdmin is bool
      && data.termsAccepted is bool;
    }

    function isValidAddress(addr) {
      return addr.keys().hasOnly([
        'streetName',
        'streetNumber',
        'zipCode',
        'city',
        'state',
        'cpf',
        'phone'
      ])
      && addr.streetName is string
      && addr.streetNumber is string
      && addr.zipCode.matches('^[0-9]{5}-?[0-9]{3}$')
      && addr.city is string
      && addr.state.size() == 2
      && addr.cpf.size() >= 11
      && addr.phone.size() >= 10;
    }

    function isValidOrderItems(items) {
      return items is list
        && items.size() > 0
        && items[0].keys().hasOnly([
          'productId',
          'productGroupId',
          'productName',
          'imageUrl',
          'quantity',
          'unitPriceAtOrder',
          'selectedSize',
          'selectedColor',
          'selectedMaterial',
          'readyMade'
        ])
        && items[0].quantity > 0;
    }

    /* =============================
       USERS
    ============================== */

    match /users/{userId} {
      allow get: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.isAdmin == false
        && request.resource.data.createdAt == request.time
        && isValidUserProfile(request.resource.data);

      allow update: if isOwner(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isAdmin == resource.data.isAdmin;
      
      /* ENDEREÇOS */
      match /addresses/{addressId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isValidAddress(request.resource.data);
      }

      /* CARRINHO */
      match /carts/{cartId} {
        allow read, write, delete: if isOwner(userId);
      }

      /* PEDIDOS */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();

        allow create: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'Processing'
          && isValidAddress(request.resource.data.shippingAddress)
          && isValidOrderItems(request.resource.data.items)
          && request.resource.data.createdAt == request.time;

        allow update: if isAdmin()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      /* SOLICITAÇÕES SOB DEMANDA */
      match /custom_requests/{requestId} {
        allow get, list: if isOwner(userId) || isAdmin();

        allow create: if isOwner(userId)
          && request.resource.data.status == 'Pending'
          && isValidAddress(request.resource.data.shippingAddress)
          && request.resource.data.createdAt == request.time;

        allow update: if (
          isAdmin() ||
          (
            isOwner(userId)
            && resource.data.status == 'Pending'
            && request.resource.data.status == 'Cancelled'
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'updatedAt'])
          )
        );

        allow delete: if false;
      }
    }

    /* =============================
       COLEÇÕES PÚBLICAS
    ============================== */

    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /product_inventory/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "aymatsu00@gmail.com" || 
         request.auth.token.email == "hashiramanakamoto0@gmail.com");
    }

    /* =============================
        USER PROFILES
    ============================== */

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      
      // User-specific subcollections
      match /custom_requests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin() || isOwner(userId);
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }
    }

    /* =============================
        COLLECTION GROUP RULES
    ============================== */
    
    match /{path=**}/custom_requests/{requestId} {
      allow list: if isAdmin();
    }
    
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get, list: if true;
      allow write: if false;
    }
    
    match /security_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
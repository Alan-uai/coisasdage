
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    /* =============================
        USER PROFILES
    ============================== */

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      
      // User-specific subcollections (orders and custom_requests)
      // Users can manage their own, admins can manage everything
      match /custom_requests/{requestId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /* =============================
        COLLECTION GROUP RULES
    ============================== */
    
    // Explicit rule for collectionGroup queries on custom_requests
    // This is required for admins to list all requests globally
    match /{path=**}/custom_requests/{requestId} {
      allow list: if isAdmin();
    }

    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get, list: if true;
      allow write: if false;
    }
    
    match /security_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}

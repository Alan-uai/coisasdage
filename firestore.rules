rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    function isOwnedData(userId) {
      return request.resource.data.userId == userId;
    }
    
    function isOwnershipImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function isSafeRead() {
      // Ensure queries are limited for performance and security.
      return request.query.limit != null && request.query.limit <= 20;
    }

    /* =============================
        GLOBAL BLOCK
    ============================== */
    
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    /* =============================
        USER DATA & SUBCOLLECTIONS
    ============================== */

    match /users/{userId} {

      // A user can access their own profile.
      allow get, create, update: if isOwner(userId);
      allow delete: if false;

      // --- ADDRESSES ---
      match /addresses/{addressId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isSafeRead();
        allow create: if isOwner(userId) && isOwnedData(userId);
        allow update, delete: if isOwner(userId);
      }

      // --- CARTS ---
      match /carts/{cartId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isSafeRead();
        allow create: if isOwner(userId) && isOwnedData(userId);
        allow update, delete: if isOwner(userId);
        
        match /items/{cartItemId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId) && isSafeRead();
          allow create, update, delete: if isOwner(userId);
        }
      }

      // --- ORDERS ---
      match /orders/{orderId} {
        // Separated get and list to avoid isSafeRead failing on single doc listeners
        allow get: if isOwner(userId);
        allow list: if isOwner(userId) && isSafeRead();
        
        allow create: if isOwner(userId) && isOwnedData(userId);
        
        // Allow owner to update order details (payment status, IDs, address)
        allow update: if isOwner(userId);
        
        // Allow owner to delete order (used when redoing a cancelled order)
        allow delete: if isOwner(userId);

        match /items/{orderItemId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId) && isSafeRead();
          allow create: if isOwner(userId);
          allow update: if false;
          allow delete: if isOwner(userId);
        }
      }
    }
    
    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get: if true;
      allow list: if isSafeRead();
      allow write: if false;
    }
    
    /* =============================
        WRITE-ONLY COLLECTIONS
    ============================== */
    
    match /security_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
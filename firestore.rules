
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    /* =============================
        USER PROFILES
    ============================== */

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /* =============================
        CUSTOM REQUESTS (On Demand)
    ============================== */

    match /custom_requests/{requestId} {
      // 'get' permite ler um documento específico
      allow get: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
      
      // 'list' permite realizar consultas (queries) na coleção
      // O Firestore exige que a query tenha o filtro where('userId', '==', uid)
      allow list: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
      
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }
    
    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get, list: if true;
      allow write: if false;
    }
    
    match /security_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isNotAnonymous() {
      return request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    function isOwnedData(userId) {
      return request.resource.data.userId == userId;
    }
    
    function isOwnershipImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function isSafeRead() {
      return request.query.limit != null && request.query.limit <= 20;
    }

    /* =============================
        GLOBAL BLOCK
    ============================== */
    
    // By default, deny all reads and writes.
    // Specific rules below will grant access.
    match /{document=**} {
      allow read, write: if false;
    }

    /* =============================
        USER DATA & SUBCOLLECTIONS
    ============================== */

    match /users/{userId} {

      // A verified, non-anonymous user can only get their own profile.
      allow get: if isOwner(userId) && isEmailVerified() && isNotAnonymous();
      
      // A user can create their own profile, but only with specific fields.
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasOnly(['displayName', 'email', 'createdAt'])
                    && request.resource.data.email == request.auth.token.email;
      
      // A user can only update their own 'displayName'.
      allow update: if isExistingOwner(userId) && request.resource.data.keys().hasOnly(['displayName']);
      
      allow delete: if false; // Users cannot delete their profiles.

      // --- ADDRESSES ---
      match /addresses/{addressId} {
        allow get, list: if isOwner(userId) && isSafeRead();
        allow create: if isOwner(userId) && isOwnedData(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
      }

      // --- CARTS ---
      match /carts/{cartId} {
        allow get, list: if isOwner(userId) && isSafeRead();
        allow create: if isOwner(userId) && isOwnedData(userId);
        allow update: if isExistingOwner(userId) && isOwnershipImmutable();
        allow delete: if isExistingOwner(userId);
        
        // --- CART ITEMS ---
        match /items/{cartItemId} {
          allow get, list: if isOwner(userId) && isSafeRead();
          allow create: if isOwner(userId) && request.resource.data.cartId == cartId;
          allow update, delete: if isExistingOwner(userId);
        }
      }

      // --- ORDERS ---
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) && isSafeRead();
        allow create: if isOwner(userId) && isOwnedData(userId);
        
        // Orders are immutable by users once created.
        allow update, delete: if false;

        // --- ORDER ITEMS ---
        match /items/{orderItemId} {
          allow get, list: if isOwner(userId) && isSafeRead();
          allow create: if isOwner(userId) && request.resource.data.orderId == orderId;
          
          // Order items are also immutable.
          allow update, delete: if false;
        }
      }
    }
    
    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      // Essential for e-commerce: Anyone can browse the product catalog.
      allow get: if true;
      // List operations are limited to prevent large-scale data dumps.
      allow list: if isSafeRead();
      
      // Writes are restricted. Should be handled by a secure backend/admin role.
      allow write: if false;
    }
    
    /* =============================
        WRITE-ONLY COLLECTIONS
    ============================== */
    
    match /security_logs/{logId} {
      // Any authenticated user can write a log entry.
      allow create: if isAuthenticated() && request.resource.data.keys().hasAll(['userId', 'event', 'createdAt']);
      
      // No one can read, update, or delete logs from the client.
      allow read, update, delete: if false;
    }
  }
}

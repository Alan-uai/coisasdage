
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == "true"
        );
    }

    /* =============================
        USER PROFILES
    ============================== */

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /* =============================
        CUSTOM REQUESTS (On Demand)
    ============================== */

    match /custom_requests/{requestId} {
      // Regras separadas para garantir que o usuário comum não dependa de checagens de admin
      // Isso resolve o erro de permissão na página de pedidos (/orders)
      
      // 1. Permite que o usuário liste suas próprias solicitações (Dono)
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // 2. Permite que o administrador liste tudo (Admin)
      allow list: if isAdmin();
      
      // 3. Permite acesso individual para leitura
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // 4. Permite criação apenas para o próprio usuário
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // 5. Atualização e deleção seguem as permissões de dono ou admin
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get, list: if true;
      allow write: if false;
    }
    
    match /security_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =============================
        SECURITY FUNCTIONS
    ============================== */

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "aymatsu00@gmail.com" || 
        request.auth.token.email == "hashiramanakamoto0@gmail.com"
      );
    }

    /* =============================
        COLLECTION GROUP RULES
        Crucial para permitir listagem global (Admin Dashboard)
    ============================== */
    
    match /{path=**}/custom_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow write: if isAdmin();
    }
    
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow write: if isAdmin();
    }

    /* =============================
        USER PROFILES
    ============================== */

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Regras específicas para subcoleções (acesso direto via path)
      match /custom_requests/{requestId} {
        allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if isAdmin();
      }

      match /orders/{orderId} {
        allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if isAdmin();
      }
      
      match /carts/{cartId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
        match /items/{itemId} {
          allow read, write: if isAuthenticated() && request.auth.uid == userId;
        }
      }
    }

    /* =============================
        PUBLIC COLLECTIONS
    ============================== */
    
    match /products/{productId} {
      allow get, list: if true;
    }
  }
}

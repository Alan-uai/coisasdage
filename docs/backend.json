
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents the profile information for a user.",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "termsAccepted": { "type": "boolean" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "CustomRequest": {
      "title": "CustomRequest",
      "type": "object",
      "description": "A bundle of items requested by a user for review.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "imageUrl": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPriceAtOrder": { "type": "number" },
              "selectedSize": { "type": "string" },
              "selectedColor": { "type": "string" },
              "selectedMaterial": { "type": "string" }
            }
          }
        },
        "totalBasePrice": { "type": "number" },
        "finalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Contested", "AddedToCart", "Cancelled"] },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "status", "createdAt"]
    },
    "ProductInventory": {
        "title": "ProductInventory",
        "type": "object",
        "description": "Represents the stock quantity for a ready-made product.",
        "properties": {
            "quantity": { "type": "number", "description": "The number of items available in stock." }
        },
        "required": ["quantity"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores user profile information."
        }
      },
      {
        "path": "/users/{userId}/custom_requests/{requestId}",
        "definition": {
          "entityName": "CustomRequest",
          "schema": { "$ref": "#/backend/entities/CustomRequest" },
          "description": "User specific on-demand requests for admin approval."
        }
      },
      {
        "path": "/product_inventory/{productId}",
        "definition": {
          "entityName": "ProductInventory",
          "schema": { "$ref": "#/backend/entities/ProductInventory" },
          "description": "Stores the stock count for ready-made products."
        }
      }
    ]
  }
}
